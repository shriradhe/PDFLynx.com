DOMAIN=https://pdflynx.com

# LibreOffice conversion settings (Word <-> PDF)
# Normally you just install LibreOffice and ensure `soffice` is on PATH.
# If it's not, set one or more full paths to the `soffice`/`soffice.exe` binary:
# - Windows example:
#   LIBREOFFICE_SOFFICE_BINARY_PATH=C:\Program Files\LibreOffice\program\soffice.exe
# - Linux example:
#   LIBREOFFICE_SOFFICE_BINARY_PATHS=/usr/bin/soffice,/opt/libreoffice/program/soffice
LIBREOFFICE_SOFFICE_BINARY_PATH=
LIBREOFFICE_SOFFICE_BINARY_PATHS=

PORT=5000
MONGODB_URI=mongodb://localhost:27017/ilovepdf
JWT_SECRET=supersecretjwtkey_please_change_in_production
CLIENT_URL=http://localhost:5173
